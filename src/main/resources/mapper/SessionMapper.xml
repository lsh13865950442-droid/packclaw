<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.packclaw.mapper.SessionMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.packclaw.model.po.Session">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="ip" property="ip" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="BOOLEAN"/>
        <result column="query" property="query" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, title, ip, status, query, create_time, update_time
    </sql>

    <!-- 插入会话 -->
    <insert id="insert" parameterType="com.packclaw.model.po.Session">
        INSERT INTO session
            (id, title, ip, status, query, create_time, update_time)
        VALUES
            (#{id}, #{title}, #{ip}, #{status}, #{query}, #{createTime}, #{updateTime})
    </insert>

    <!-- 根据ID更新会话 -->
    <update id="updateById" parameterType="com.packclaw.model.po.Session">
        UPDATE session
        <set>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="ip != null">
                ip = #{ip},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="query != null">
                query = #{query},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询会话 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM session
        WHERE id = #{id}
    </select>

    <!-- 查询会话列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM session
        WHERE status = true
        ORDER BY create_time DESC
    </select>

    <!-- 根据名称查询会话列表（支持模糊查询） -->
    <select id="selectByUserIdAndName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM session
        WHERE status = true
        <if test="name != null and name != ''">
            AND title LIKE CONCAT('%', #{name}, '%')
        </if>
        ORDER BY create_time DESC
    </select>

    <!-- 根据ID删除会话（逻辑删除） -->
    <update id="deleteById">
        UPDATE session
        SET status = false
        WHERE id = #{id}
    </update>

    <!-- 删除所有会话（逻辑删除） -->
    <update id="deleteByUserId">
        UPDATE session
        SET status = false
        WHERE 1=1
    </update>

    <update id="updateNameById">
        UPDATE session
        SET title = #{title}
        WHERE id = #{sessionId}
    </update>
</mapper>
